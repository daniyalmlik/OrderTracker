{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "OrderTracker",
    "Audience": "OrderTrackerClient",
    "SecretKey": "",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "order-events",
    "ConsumerGroup": "orderpulse-notifications"
  }
}
